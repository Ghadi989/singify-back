# Copy this file to .env and fill in the values
JWT_SECRET=changeMeInProductionWithALongRandomString123456
GCS_BUCKET_NAME=singify-dev-bucket
GCS_CREDENTIALS_FILE=./gcs-credentials.json
GCS_CREDENTIALS_PATH=/app/gcs-credentials.json

# Allowed frontend origins for CORS — comma-separated, no spaces
# Production example: CORS_ALLOWED_ORIGINS=https://singify.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Spotify API — get credentials at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
